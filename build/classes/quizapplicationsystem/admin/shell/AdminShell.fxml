<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<BorderPane minHeight="720.0" minWidth="1280.0" prefHeight="1080.0" prefWidth="1920.0"
            styleClass="admin-root" stylesheets="@AdminShell.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="quizapplicationsystem.admin.shell.AdminShellController">
    <fx:define>
        <ToggleGroup fx:id="navigationGroup" />
    </fx:define>

    <left>
        <VBox maxWidth="272.0" minWidth="272.0" prefWidth="272.0" styleClass="sidebar">
            <padding>
                <Insets bottom="22.0" left="18.0" right="18.0" top="22.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="brand-row">
                    <children>
                        <StackPane minHeight="38.0" minWidth="38.0"
                                   prefHeight="38.0" prefWidth="38.0"
                                   styleClass="brand-mark">
                            <children>
                                <Label styleClass="brand-letter" text="Q" />
                            </children>
                        </StackPane>
                        <VBox spacing="1.0">
                            <children>
                                <Label styleClass="brand-name" text="Quiz System" />
                                <Label styleClass="brand-caption" text="ADMIN CONSOLE" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <Separator styleClass="sidebar-separator">
                    <VBox.margin>
                        <Insets bottom="23.0" top="23.0" />
                    </VBox.margin>
                </Separator>

                <Label styleClass="nav-section-label" text="WORKSPACE" />

                <VBox spacing="5.0">
                    <VBox.margin>
                        <Insets top="9.0" />
                    </VBox.margin>
                    <children>
                        <ToggleButton fx:id="dashboardNavButton" alignment="CENTER_LEFT"
                                      contentDisplay="LEFT" graphicTextGap="14.0"
                                      maxWidth="1.7976931348623157E308"
                                      onAction="#handleNavigation" selected="true"
                                      styleClass="nav-button" text="Dashboard"
                                      toggleGroup="$navigationGroup" userData="DASHBOARD">
                            <graphic>
                                <SVGPath content="M3 13h8V3H3v10zm0 8h8v-6H3v6zm10 0h8V11h-8v10zm0-18v6h8V3h-8z"
                                         styleClass="nav-icon" />
                            </graphic>
                        </ToggleButton>

                        <ToggleButton fx:id="studentsNavButton" alignment="CENTER_LEFT"
                                      contentDisplay="LEFT" graphicTextGap="14.0"
                                      maxWidth="1.7976931348623157E308"
                                      onAction="#handleNavigation" styleClass="nav-button"
                                      text="Students" toggleGroup="$navigationGroup"
                                      userData="STUDENTS">
                            <graphic>
                                <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                         styleClass="nav-icon" />
                            </graphic>
                        </ToggleButton>

                        <ToggleButton fx:id="teachersNavButton" alignment="CENTER_LEFT"
                                      contentDisplay="LEFT" graphicTextGap="14.0"
                                      maxWidth="1.7976931348623157E308"
                                      onAction="#handleNavigation" styleClass="nav-button"
                                      text="Teachers" toggleGroup="$navigationGroup"
                                      userData="TEACHERS">
                            <graphic>
                                <SVGPath content="M12 3 1 9l4 2.18v6L12 21l7-3.82v-6L21 10v7h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 16l-5 2.73L7 16v-3.73L12 15l5-2.73V16z"
                                         styleClass="nav-icon" />
                            </graphic>
                        </ToggleButton>

                        <ToggleButton fx:id="quizzesNavButton" alignment="CENTER_LEFT"
                                      contentDisplay="LEFT" graphicTextGap="14.0"
                                      maxWidth="1.7976931348623157E308"
                                      onAction="#handleNavigation" styleClass="nav-button"
                                      text="Quiz library" toggleGroup="$navigationGroup"
                                      userData="QUIZZES">
                            <graphic>
                                <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-8 14H6v-2h5v2zm0-4H6v-2h5v2zm0-4H6V7h5v2zm3.41 8L12 14.59 13.41 13 15 14.59 18.59 11 20 12.41 15 17.41z"
                                         styleClass="nav-icon" />
                            </graphic>
                        </ToggleButton>

                        <ToggleButton fx:id="resultsNavButton" alignment="CENTER_LEFT"
                                      contentDisplay="LEFT" graphicTextGap="14.0"
                                      maxWidth="1.7976931348623157E308"
                                      onAction="#handleNavigation" styleClass="nav-button"
                                      text="Results" toggleGroup="$navigationGroup"
                                      userData="RESULTS">
                            <graphic>
                                <SVGPath content="M3 13h2v8H3v-8zm4-6h2v14H7V7zm4 3h2v11h-2V10zm4-7h2v18h-2V3zm4 5h2v13h-2V8z"
                                         styleClass="nav-icon" />
                            </graphic>
                        </ToggleButton>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <VBox spacing="9.0" styleClass="sidebar-status-card">
                    <padding>
                        <Insets bottom="14.0" left="14.0" right="14.0" top="14.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Region minHeight="7.0" minWidth="7.0"
                                        prefHeight="7.0" prefWidth="7.0"
                                        styleClass="online-dot" />
                                <Label styleClass="status-title" text="ROLE ACCESS ACTIVE" />
                            </children>
                        </HBox>
                        <Label styleClass="status-copy"
                               text="Admin permissions are applied to this session."
                               wrapText="true" />
                    </children>
                </VBox>

                <ToggleButton fx:id="settingsNavButton" alignment="CENTER_LEFT"
                              contentDisplay="LEFT" graphicTextGap="14.0"
                              maxWidth="1.7976931348623157E308"
                              onAction="#handleNavigation" styleClass="nav-button"
                              text="Settings" toggleGroup="$navigationGroup"
                              userData="SETTINGS">
                    <VBox.margin>
                        <Insets top="14.0" />
                    </VBox.margin>
                    <graphic>
                        <SVGPath content="M19.43 12.98c.04-.32.07-.65.07-.98s-.03-.66-.08-.98l2.11-1.65c.19-.15.24-.42.12-.64l-2-3.46c-.12-.22-.37-.31-.6-.22l-2.49 1c-.52-.4-1.08-.73-1.69-.98L14.5 2.42C14.47 2.18 14.25 2 14 2h-4c-.25 0-.46.18-.5.42L9.13 5.07c-.61.25-1.18.59-1.69.98l-2.49-1c-.23-.08-.48 0-.6.22l-2 3.46c-.13.22-.07.49.12.64l2.11 1.65c-.04.32-.08.66-.08.98s.03.66.08.98l-2.11 1.65c-.19.15-.24.42-.12.64l2 3.46c.12.22.37.31.6.22l2.49-1c.52.4 1.08.73 1.69.98l.37 2.65c.04.24.25.42.5.42h4c.25 0 .46-.18.5-.42l.37-2.65c.61-.25 1.18-.58 1.69-.98l2.49 1c.23.08.48 0 .6-.22l2-3.46c.12-.22.07-.49-.12-.64l-2.1-1.65zM12 15.5A3.5 3.5 0 1 1 12 8a3.5 3.5 0 0 1 0 7.5z"
                                 styleClass="nav-icon" />
                    </graphic>
                </ToggleButton>

                <Separator styleClass="sidebar-separator">
                    <VBox.margin>
                        <Insets bottom="16.0" top="16.0" />
                    </VBox.margin>
                </Separator>

                <HBox alignment="CENTER_LEFT" spacing="11.0" styleClass="account-row">
                    <children>
                        <StackPane minHeight="36.0" minWidth="36.0"
                                   prefHeight="36.0" prefWidth="36.0"
                                   styleClass="account-avatar">
                            <children>
                                <Label fx:id="accountInitialsLabel" styleClass="account-initials"
                                       text="SA" />
                            </children>
                        </StackPane>
                        <VBox HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308" spacing="1.0">
                            <children>
                                <Label fx:id="accountNameLabel" maxWidth="160.0"
                                       styleClass="account-name" text="System Admin"
                                       textOverrun="ELLIPSIS" />
                                <Label styleClass="account-role" text="Administrator" />
                            </children>
                        </VBox>
                        <Button fx:id="logoutButton" accessibleText="Sign out"
                                contentDisplay="GRAPHIC_ONLY" onAction="#handleLogout"
                                styleClass="icon-button-dark">
                            <graphic>
                                <SVGPath content="M10.09 15.59 11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3h-8c-1.1 0-2 .9-2 2v4h2V5h8v14h-8v-4H9v4c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"
                                         styleClass="logout-icon" />
                            </graphic>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </left>

    <center>
        <BorderPane styleClass="workspace">
            <top>
                <HBox alignment="CENTER_LEFT" minHeight="76.0" prefHeight="76.0"
                      styleClass="topbar">
                    <padding>
                        <Insets left="34.0" right="34.0" />
                    </padding>
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="9.0">
                            <children>
                                <Label styleClass="breadcrumb-muted" text="Admin" />
                                <Label styleClass="breadcrumb-separator" text="/" />
                                <Label fx:id="breadcrumbLabel" styleClass="breadcrumb-current"
                                       text="Dashboard" />
                            </children>
                        </HBox>

                        <Region HBox.hgrow="ALWAYS" />

                        <StackPane prefHeight="40.0" prefWidth="300.0" styleClass="search-shell">
                            <children>
                                <TextField fx:id="globalSearchField" accessibleText="Search accounts"
                                           maxWidth="1.7976931348623157E308"
                                           promptText="Search recent accounts..."
                                           styleClass="global-search" />
                                <SVGPath content="M9.5 3a6.5 6.5 0 1 0 3.98 11.64L18.85 20 20 18.85l-5.36-5.37A6.5 6.5 0 0 0 9.5 3zm0 2a4.5 4.5 0 1 1 0 9 4.5 4.5 0 0 1 0-9z"
                                         mouseTransparent="true" styleClass="search-icon"
                                         StackPane.alignment="CENTER_LEFT">
                                    <StackPane.margin>
                                        <Insets left="13.0" />
                                    </StackPane.margin>
                                </SVGPath>
                                <Label mouseTransparent="true" styleClass="search-hint" text="/"
                                       StackPane.alignment="CENTER_RIGHT">
                                    <StackPane.margin>
                                        <Insets right="10.0" />
                                    </StackPane.margin>
                                </Label>
                            </children>
                        </StackPane>

                        <Separator orientation="VERTICAL" prefHeight="26.0"
                                   styleClass="topbar-separator">
                            <HBox.margin>
                                <Insets left="18.0" right="18.0" />
                            </HBox.margin>
                        </Separator>

                        <Label styleClass="environment-pill" text="ADMIN" />
                    </children>
                </HBox>
            </top>

            <center>
                <StackPane styleClass="content-host">
                    <children>
                        <fx:include fx:id="dashboardView" source="../dashboard/DashboardView.fxml" />

                        <VBox fx:id="modulePlaceholder" alignment="CENTER" managed="false"
                              maxWidth="650.0" spacing="13.0" visible="false">
                            <children>
                                <StackPane minHeight="64.0" minWidth="64.0"
                                           prefHeight="64.0" prefWidth="64.0"
                                           styleClass="placeholder-icon-shell">
                                    <children>
                                        <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 15H6v-2h6v2zm6-4H6v-2h12v2zm0-4H6V8h12v2z"
                                                 styleClass="placeholder-icon" />
                                    </children>
                                </StackPane>
                                <Label fx:id="placeholderEyebrowLabel" styleClass="placeholder-eyebrow"
                                       text="NEXT MODULE" />
                                <Label fx:id="placeholderTitleLabel" styleClass="placeholder-title"
                                       text="Manage student access" />
                                <Label fx:id="placeholderDescriptionLabel" alignment="CENTER"
                                       maxWidth="520.0" styleClass="placeholder-description"
                                       text="This navigation state is ready for its dedicated feature view."
                                       textAlignment="CENTER" wrapText="true" />
                                <Button onAction="#handleBackToDashboard" styleClass="secondary-button"
                                        text="Return to dashboard">
                                    <VBox.margin>
                                        <Insets top="8.0" />
                                    </VBox.margin>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </StackPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>

