<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.SVGPath?>

<ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER"
            pannable="false" styleClass="dashboard-scroll" vbarPolicy="AS_NEEDED"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="quizapplicationsystem.admin.dashboard.DashboardController">
    <content>
        <VBox fx:id="dashboardContent" spacing="22.0" styleClass="dashboard-content">
            <padding>
                <Insets bottom="38.0" left="38.0" right="38.0" top="34.0" />
            </padding>
            <children>
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <VBox spacing="5.0">
                            <children>
                                <Label fx:id="welcomeLabel" styleClass="page-title"
                                       text="Good morning, Admin" />
                                <HBox alignment="CENTER_LEFT" spacing="9.0">
                                    <children>
                                        <Label fx:id="dateLabel" styleClass="page-subtitle"
                                               text="Tuesday, July 21, 2026" />
                                        <Region minHeight="4.0" minWidth="4.0"
                                                prefHeight="4.0" prefWidth="4.0"
                                                styleClass="metadata-dot" />
                                        <Label styleClass="page-subtitle"
                                               text="Here’s the account overview." />
                                        <Label fx:id="dataStatusLabel" styleClass="data-status-live"
                                               text="Live data" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox spacing="10.0">
                            <children>
                                <Button onAction="#refreshData" styleClass="secondary-button"
                                        text="Refresh">
                                    <graphic>
                                        <SVGPath content="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.09 0-7.19 3.72-6.39 7.69L3.55 9.63C2.27 14.27 5.75 19 12 19c3.14 0 5.86-1.74 7.25-4.31l-1.45-1.45A6.003 6.003 0 0 1 12 17c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 10h7V3l-2.35 3.35z"
                                                 styleClass="button-icon" />
                                    </graphic>
                                </Button>
                                <Button onAction="#handleAddAccount" text="Add account">
                                    <styleClass>
                                        <String fx:value="primary-button" />
                                    </styleClass>
                                    <graphic>
                                        <SVGPath content="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"
                                                 styleClass="button-icon-inverse" />
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <GridPane hgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="25.0" />
                    </columnConstraints>
                    <children>
                        <VBox maxWidth="1.7976931348623157E308" minHeight="150.0"
                              prefHeight="150.0" spacing="13.0" GridPane.columnIndex="0">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="metric-card" />
                                <String fx:value="metric-card-primary" />
                            </styleClass>
                            <padding>
                                <Insets bottom="20.0" left="21.0" right="21.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="metric-label-inverse" text="TOTAL ACCOUNTS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="metric-icon-shell-inverse">
                                            <children>
                                                <SVGPath content="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                                         styleClass="metric-icon-inverse" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                                <Label fx:id="totalAccountsLabel" styleClass="metric-value-inverse"
                                       text="0" />
                                <Label styleClass="metric-caption-inverse"
                                       text="Across every access role" />
                            </children>
                        </VBox>

                        <VBox maxWidth="1.7976931348623157E308" minHeight="150.0"
                              prefHeight="150.0" spacing="13.0" GridPane.columnIndex="1">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="metric-card" />
                            </styleClass>
                            <padding>
                                <Insets bottom="20.0" left="21.0" right="21.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="metric-label" text="STUDENTS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="metric-icon-shell-blue">
                                            <children>
                                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                                         styleClass="metric-icon-blue" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                                <Label fx:id="studentsLabel" styleClass="metric-value" text="0" />
                                <Label styleClass="metric-caption" text="Learner accounts" />
                            </children>
                        </VBox>

                        <VBox maxWidth="1.7976931348623157E308" minHeight="150.0"
                              prefHeight="150.0" spacing="13.0" GridPane.columnIndex="2">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="metric-card" />
                            </styleClass>
                            <padding>
                                <Insets bottom="20.0" left="21.0" right="21.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="metric-label" text="TEACHERS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="metric-icon-shell-amber">
                                            <children>
                                                <SVGPath content="M12 3 1 9l4 2.18v6L12 21l7-3.82v-6L21 10v7h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9z"
                                                         styleClass="metric-icon-amber" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                                <Label fx:id="teachersLabel" styleClass="metric-value" text="0" />
                                <Label styleClass="metric-caption" text="Quiz creators" />
                            </children>
                        </VBox>

                        <VBox maxWidth="1.7976931348623157E308" minHeight="150.0"
                              prefHeight="150.0" spacing="13.0" GridPane.columnIndex="3">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="metric-card" />
                            </styleClass>
                            <padding>
                                <Insets bottom="20.0" left="21.0" right="21.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label styleClass="metric-label" text="ADMINISTRATORS" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="metric-icon-shell-green">
                                            <children>
                                                <SVGPath content="M12 1 3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"
                                                         styleClass="metric-icon-green" />
                                            </children>
                                        </StackPane>
                                    </children>
                                </HBox>
                                <Label fx:id="administratorsLabel" styleClass="metric-value" text="0" />
                                <Label styleClass="metric-caption" text="System managers" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <GridPane hgap="16.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="38.0" />
                        <ColumnConstraints hgrow="ALWAYS" percentWidth="62.0" />
                    </columnConstraints>
                    <children>
                        <VBox maxWidth="1.7976931348623157E308" minHeight="330.0"
                              prefHeight="330.0" spacing="18.0" GridPane.columnIndex="0">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="breakdown-card" />
                            </styleClass>
                            <padding>
                                <Insets bottom="22.0" left="23.0" right="23.0" top="22.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="3.0">
                                            <children>
                                                <Label styleClass="card-title" text="Access distribution" />
                                                <Label styleClass="card-description"
                                                       text="Accounts grouped by role" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label styleClass="neutral-pill" text="RBAC" />
                                    </children>
                                </HBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label styleClass="breakdown-label" text="Students" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="studentBreakdownLabel"
                                                       styleClass="breakdown-value" text="0 accounts" />
                                            </children>
                                        </HBox>
                                        <ProgressBar fx:id="studentProgressBar" maxWidth="1.7976931348623157E308"
                                                     progress="0.0" styleClass="student-progress" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label styleClass="breakdown-label" text="Teachers" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="teacherBreakdownLabel"
                                                       styleClass="breakdown-value" text="0 accounts" />
                                            </children>
                                        </HBox>
                                        <ProgressBar fx:id="teacherProgressBar" maxWidth="1.7976931348623157E308"
                                                     progress="0.0" styleClass="teacher-progress" />
                                    </children>
                                </VBox>

                                <VBox spacing="8.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT">
                                            <children>
                                                <Label styleClass="breakdown-label" text="Administrators" />
                                                <Region HBox.hgrow="ALWAYS" />
                                                <Label fx:id="administratorBreakdownLabel"
                                                       styleClass="breakdown-value" text="0 accounts" />
                                            </children>
                                        </HBox>
                                        <ProgressBar fx:id="administratorProgressBar" maxWidth="1.7976931348623157E308"
                                                     progress="0.0" styleClass="administrator-progress" />
                                    </children>
                                </VBox>

                                <Separator styleClass="card-separator" />
                                <Label styleClass="card-footnote"
                                       text="Role assignment determines which workspace opens after authentication."
                                       wrapText="true" />
                            </children>
                        </VBox>

                        <VBox maxWidth="1.7976931348623157E308" minHeight="330.0"
                              prefHeight="330.0" spacing="12.0" GridPane.columnIndex="1">
                            <styleClass>
                                <String fx:value="surface-card" />
                                <String fx:value="accounts-card" />
                            </styleClass>
                            <padding>
                                <Insets bottom="12.0" left="22.0" right="22.0" top="20.0" />
                            </padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <VBox spacing="3.0">
                                            <children>
                                                <Label styleClass="card-title" text="Recent accounts" />
                                                <Label styleClass="card-description"
                                                       text="Latest identities added to the system" />
                                            </children>
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Button onAction="#handleManageStudents"
                                                styleClass="text-button" text="Manage accounts  →" />
                                    </children>
                                </HBox>

                                <TableView fx:id="recentAccountsTable" focusTraversable="false"
                                           maxHeight="1.7976931348623157E308"
                                           maxWidth="1.7976931348623157E308"
                                           prefHeight="252.0" styleClass="accounts-table"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="nameColumn" prefWidth="260.0" text="NAME" />
                                        <TableColumn fx:id="usernameColumn" prefWidth="210.0" text="USERNAME" />
                                        <TableColumn fx:id="roleColumn" prefWidth="160.0" text="ROLE" />
                                    </columns>
                                    <placeholder>
                                        <Label styleClass="table-placeholder" text="No accounts found" />
                                    </placeholder>
                                </TableView>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <VBox spacing="11.0">
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <children>
                                <Label styleClass="section-title" text="Quick actions" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Label styleClass="section-caption"
                                       text="Jump directly into routine admin work" />
                            </children>
                        </HBox>
                        <HBox spacing="12.0">
                            <children>
                                <Button alignment="CENTER_LEFT" contentDisplay="LEFT"
                                        graphicTextGap="12.0" maxWidth="1.7976931348623157E308"
                                        onAction="#handleManageStudents" text="Manage students"
                                        HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="quick-action-button" />
                                    </styleClass>
                                    <graphic>
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="quick-icon-shell-blue">
                                            <children>
                                                <SVGPath content="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                                                         styleClass="quick-icon-blue" />
                                            </children>
                                        </StackPane>
                                    </graphic>
                                </Button>

                                <Button alignment="CENTER_LEFT" contentDisplay="LEFT"
                                        graphicTextGap="12.0" maxWidth="1.7976931348623157E308"
                                        onAction="#handleManageTeachers" text="Manage teachers"
                                        HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="quick-action-button" />
                                    </styleClass>
                                    <graphic>
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="quick-icon-shell-amber">
                                            <children>
                                                <SVGPath content="M12 3 1 9l4 2.18v6L12 21l7-3.82v-6L21 10v7h2V9L12 3z"
                                                         styleClass="quick-icon-amber" />
                                            </children>
                                        </StackPane>
                                    </graphic>
                                </Button>

                                <Button alignment="CENTER_LEFT" contentDisplay="LEFT"
                                        graphicTextGap="12.0" maxWidth="1.7976931348623157E308"
                                        onAction="#handleOpenQuizLibrary" text="Open quiz library"
                                        HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="quick-action-button" />
                                    </styleClass>
                                    <graphic>
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="quick-icon-shell-violet">
                                            <children>
                                                <SVGPath content="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-8 14H6v-2h5v2zm0-4H6v-2h5v2zm0-4H6V7h5v2z"
                                                         styleClass="quick-icon-violet" />
                                            </children>
                                        </StackPane>
                                    </graphic>
                                </Button>

                                <Button alignment="CENTER_LEFT" contentDisplay="LEFT"
                                        graphicTextGap="12.0" maxWidth="1.7976931348623157E308"
                                        onAction="#handleViewResults" text="Review results"
                                        HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="quick-action-button" />
                                    </styleClass>
                                    <graphic>
                                        <StackPane minHeight="34.0" minWidth="34.0"
                                                   prefHeight="34.0" prefWidth="34.0"
                                                   styleClass="quick-icon-shell-green">
                                            <children>
                                                <SVGPath content="M3 13h2v8H3v-8zm4-6h2v14H7V7zm4 3h2v11h-2V10zm4-7h2v18h-2V3zm4 5h2v13h-2V8z"
                                                         styleClass="quick-icon-green" />
                                            </children>
                                        </StackPane>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </content>
</ScrollPane>

